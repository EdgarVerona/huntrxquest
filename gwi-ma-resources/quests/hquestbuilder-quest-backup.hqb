tation":"rock"},"F4":{"annotation":"rock"},"G4":{"annotation":"rock"},"H4":{"annotation":"rock"},"I4":{"annotation":"rock"},"I3":{"annotation":"rock"},"H3":{"annotation":"rock"},"G3":{"annotation":"rock"},"F3":{"annotation":"rock"},"E3":{"annotation":"rock"},"E2":{"annotation":"rock"},"F2":{"annotation":"rock"},"G2":{"annotation":"rock"},"H2":{"annotation":"rock"},"I2":{"annotation":"rock"},"B10":{"annotation":"letterC"},"B17":{"annotation":"letterD"},"K16":{"annotation":"letterF"},"R11":{"furniture":"sorcererstableN"},"J15":{"creature":"gargoyle"},"I14":{"creature":"goblin"},"K14":{"creature":"goblin"},"L9":{"annotation":"letterH"},"P11":{"creature":"zombie"},"N11":{"creature":"zombie"},"O10":{"creature":"skeleton"},"H13":{"creature":"orc"},"G23":{"furniture":"bookcaseN"},"H25":{"creature":"skeleton"},"H23":{"creature":"skeleton"},"F16":{"furniture":"fireplaceS"},"C16":{"creature":"dreadwarrior"},"D17":{"creature":"abomination"},"D11":{"furniture":"alchemistsbenchW"},"B12":{"creature":"abomination"},"F10":{"creature":"goblin"},"F7":{"creature":"orc"},"G7":{"creature":"orc"},"I6":{"creature":"orc"},"K6":{"creature":"goblin"},"L3":{"creature":"orc"},"P3":{"creature":"dreadwarrior"},"M6":{"creature":"goblin"},"H24":{"creature":"mummy"},"F23":{"creature":"abomination"},"F24":{"annotation":"letterE"},"F12":{"creature":"skeleton"}},"narrative":"Last%20time%2C%20on%20Huntr%2Fx%20Quest...%0A%0AThe%20girls%20were%20confronted%20at%20a%20gig%20by%20demons%20under%20the%20leadership%20of%20an%20unknown%20entity%20by%20the%20name%20of%20Agwi%20Hwasin.%20%20To%20their%20horror%2C%20they%20found%20that%20these%20demons%20are%20able%20to%20not%20just%20take%20the%20souls%20of%20humans%2C%20but%20also%20to%20turn%20them%20into%20demons.%20%20They%20just%20left%20the%20venue%20and%20are%20making%20their%20way%20home%20to%20tell%20Celine%20what%20transpired.%0A%0ANow%20heroes%2C%20prepare%20yourselves%20for%20Chapter%202%3A%20Backalley%20Brawl.%0A%0ALeaving%20the%20venue%2C%20you%20make%20your%20way%20through%20the%20back%20alleys%20of%20Seoul%20to%20head%20home%20and%20tell%20Celine%20about%20everything%20you%20saw.%20%20But%20to%20your%20dismay%2C%20the%20stores%20appear%20to%20be%20overrun%20with%20demons!%20%20Try%20to%20rescue%20the%20four%20innocent%20people%20from%20this%20invasion%2C%20before%20it's%20too%20late.%0A%0AFor%20every%20innocent%20person%20that%20you%20save%2C%20each%20of%20you%20will%20get%20100gp.%20%20If%20you%20can%20save%20all%204%20of%20the%20innocent%20people%2C%20you'll%20each%20get%20an%20extra%20100gp!","notes":"%C2%A7MD%C2%A7**X**%20-%20The%20girls%20start%20just%20off%20the%20map%20here.%0A%0A**A**%20-%20*%22You%20peer%20down%20the%20hole.%20%20It%20appears%20to%20be%20some%20kind%20of%20tunnel.%22*%20%0A%0AAllow%20them%20to%20choose%20to%20pass%20through%2C%20in%20which%20case%20they%20go%20to%20the%20other%20A%20immediately%20and%20you%20say%20*%22It%20seems%20you%20have%20found%20the%20unfortunate%20person%20who%20you%20heard%20screaming%20earlier%20-%20and%20you've%20found%20your%20way%20into%20an%20ambush!%22*%0A%0A**B**%20-%20%22You%20open%20the%20door%20to%20see%20a%20store%20filled%20with%20feudal-era%20weaponry%2C%20but%20no%20civilians.%20%20It%20appears%20the%20demons%20in%20this%20room%20got%20here%20before%20you%20did%2C%20they've%20armed%20themselves!%22%20%0A%0ADemons%20get%20%2B1%20attack%20in%20this%20encounter.%20%20%0A%0AIf%20the%20heroes%20win%2C%20they%20each%20find%20a%20Broadsword%20among%20the%20demon-scavenged%20items%2C%20which%20they%20can%20sell%20for%20125gp.%0A%0A**C**%20-%20*%22As%20you%20open%20the%20door%20to%20this%20shop%2C%20you%20see%20a%20frightened%20storekeeper%20huddled%20against%20the%20far%20wall.%20%20The%20closest%20Fimir%20demon%20is%20starting%20to%20envelop%20him%20in%20purple%20smoke.%20%20You%20must%20help%20him!%22*%0A%0AThe%20heroes%20have%203%20Gwi-Ma%20turns%20to%20save%20him%3A%20at%20the%20start%20of%20the%204th%20Gwi-Ma%20turn%2C%20the%20captive%20will%20turn%20into%20a%20zombie.%20%20Each%20round%2C%20say%20something%20ominous%20about%20the%20purple%20smoke.%20%20The%20closest%20fimir%20will%20stop%20his%20incantation%20and%20attack%20the%20heroes%20if%20attacked.%0A%0A**D**%20-%20*%22You%20find%20a%20shopper%20backing%20away%20from%20a%20group%20of%20mean-looking%20demons.%20%20The%20Fimir%20demon%20appears%20to%20be%20just%20starting%20an%20incantation%20of%20purple%20smoke%2C%20and%20must%20be%20stopped%20at%20all%20costs.%22*%0A%0AThe%20heroes%20have%203%20rounds%20of%20combat%20to%20save%20the%20person%3A%20at%20the%20start%20of%20the%204th%20Gwi-Ma%20turn%2C%20the%20captive%20will%20turn%20into%20a%20zombie.%20%20Each%20round%2C%20say%20something%20ominous%20about%20the%20purple%20smoke.%20%20The%20closest%20fimir%20will%20stop%20his%20incantation%20and%20attack%20the%20heroes%20if%20attacked.%0A%0A**E**%20-%20*%22The%20book%20seller%20is%20trapped%20in%20a%20corner!%20%20A%20fimir%20is%20attempting%20to%20cast%20his%20purple%20smoke%20to%20turn%20him%20into%20a%20demon.%20%20Stop%20him!%22*%0A%0AThe%20heroes%20have%203%20rounds%20of%20combat%20to%20save%20the%20person%3A%20at%20the%20start%20of%20the%204th%20Gwi-Ma%20turn%2C%20the%20captive%20will%20turn%20into%20a%20zombie.%20%20Each%20round%2C%20say%20something%20ominous%20about%20the%20purple%20smoke.%20%20The%20closest%20fimir%20will%20stop%20his%20incantation%20and%20attack%20the%20heroes%20if%20attacked.%0A%0A**F**%20-%20Upon%20defeating%20the%20enemies%20in%20the%20room%2C%20say%20*%22The%20frightened%20man%20you%20just%20rescued%20runs%20to%20your%20side%2C%20elated%20to%20see%20you.%20%20'My%20name%20is%20Bobby%2C%20and%20you%20girls%20are%20amazing!%20%20Hey...%20I%20think%20I%20recognize%20you%2C%20you're%20Huntr%2Fx!%20%20Do%20you%20need%20a%20band%20manager%3F%20%20You%20saved%20my%20life%2C%20it's%20the%20least%20I%20could%20do%20to%20help%20you%20girls%20out!'%22%20%20Bobby%20knows%20how%20to%20use%20social%20media%20to%20give%20you%20temporary%20boosts%20to%20your%20connection%20to%20the%20Honmoon%2C%20known%20as%20Enchantments.%20%20These%20are%20now%20available%20in%20the%20store%2C%20and%20you%20can%20choose%20one%20for%20free%20to%20start%20your%20next%20mission.*%0A%0A**G**%20-%20*%22You%20don't%20see%20any%20people%20inside%2C%20but%20there's%20a%20lot%20of%20strange%20occult%20imagery%2C%20books%2C%20and%20potions%20lying%20around.%22*%20%20%0A%0AIf%20they%20defeat%20the%20monsters%20and%20search%20the%20room%2C%20the%20heroes%20find%20a%20Potion%20of%20Strength%2C%20taking%20it%20from%20the%20treasure%20deck)%0A%0A**H**%20-%20*%22When%20you%20open%20the%20door%2C%20you%20immediately%20hear%20the%20distant%20screams%20of%20someone%20further%20inside%20the%20building.%20%20You've%20got%20to%20save%20him!%22*%20(the%20doors%20inside%20this%20building%20are%20all%20open%20already)%0A%0AWhen%20the%20last%20human%20is%20either%20saved%20or%20converted%2C%20say%20the%20following%3A%0A%0A*With%20the%20demons%20dispatched%20and%20the%20streets%20appearing%20to%20be%20safe%2C%20you%20make%20your%20way%20back%20to%20the%20temple%20and%20let%20Celine%20know%20about%20everything%20you've%20seen.%0A%0ACeline%20shakes%20her%20head.%20%20%22Agwi%20Hwasin%3F%20%20This%20is%20surely%20the%20work%20of%20a%20stronger%20demon%20than%20we%20have%20encountered%20in%20a%20generation.%20%20I%20will%20head%20to%20the%20Library%20of%20Jang%20myself%2C%20and%20seek%20the%20Chronicles%20of%20Mudang%3A%20perhaps%20with%20the%20secrets%20we%20have%20discovered%20so%20far%2C%20we%20can%20find%20out%20who%20our%20foe%20is%20and%20how%20to%20overcome%20him.%20%20You%20girls%20keep%20his%20forces%20distracted%3A%20I%20don't%20believe%20that%20they%20know%20I%20still%20live%2C%20and%20I%20can%20slip%20to%20the%20library%20undetected.%22*","wanderingMonster":"Orc","style":"hq-us","homebrew":["https://images2.imgbox.com/24/fe/TnRXFdeR_o.png||8-7"]},{"id":"b7e578b8-9211-48f8-96a5-7642b4b86c97","title":"3.%20The%20Ambush","author":"","