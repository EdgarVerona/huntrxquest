rock"},"L12":{"annotation":"rock"},"L11":{"annotation":"rock"},"K11":{"annotation":"rock"},"K12":{"annotation":"rock"},"K13":{"annotation":"rock"},"K14":{"annotation":"rock"},"K15":{"annotation":"rock"},"K16":{"annotation":"rock"},"J16":{"annotation":"rock"},"J15":{"annotation":"rock"},"J14":{"annotation":"rock"},"J13":{"annotation":"rock"},"J12":{"annotation":"rock"},"J11":{"annotation":"rock"},"I11":{"annotation":"rock"},"I12":{"annotation":"rock"},"I13":{"annotation":"rock"},"I14":{"annotation":"rock"},"I15":{"annotation":"rock"},"I16":{"annotation":"rock"},"H16":{"annotation":"rock"},"H15":{"annotation":"rock"},"H14":{"annotation":"rock"},"H13":{"annotation":"rock"},"H12":{"annotation":"rock"},"H11":{"annotation":"rock"},"O16":{"creature":"mummy"},"Q16":{"creature":"mummy"},"N17":{"creature":"skeleton"},"R17":{"creature":"skeleton"},"O24":{"creature":"goblin"},"N22":{"creature":"goblin"},"O21":{"creature":"goblin"},"K23":{"creature":"goblin"},"D11":{"creature":"dreadwarrior"},"D12":{"creature":"skeleton"},"B8":{"creature":"zombie"},"D8":{"creature":"zombie"},"D4":{"creature":"orc"},"B4":{"creature":"orc"},"E7":{"creature":"orc"},"E8":{"creature":"orc"},"E9":{"creature":"orc"},"E6":{"creature":"dreadwarrior"},"G2":{"creature":"orc"},"G4":{"creature":"orc"},"I24":{"furniture":"weaponsrackN"},"F11":{"furniture":"cupboardN"},"R3":{"furniture":"tableN"},"N11":{"furniture":"bookcaseN"},"R24":{"furniture":"tombN"},"P2":{"creature":"goblin"},"P3":{"creature":"goblin"},"P4":{"creature":"goblin"},"R5":{"creature":"goblin"},"O11":{"creature":"dreadwarrior"},"P10":{"creature":"orc"},"P12":{"creature":"orc"},"Q11":{"creature":"orc"},"N20":{"furniture":"fireplaceS"},"L25":{"furniture":"tableW"},"K20":{"creature":"goblin"},"M18":{"creature":"goblin"},"M20":{"creature":"goblin"},"D19":{"creature":"abomination"},"C19":{"creature":"abomination"},"F15":{"creature":"skeleton"},"F17":{"creature":"skeleton"},"F16":{"creature":"goblin"},"B17":{"creature":"goblin"},"G25":{"creature":"gargoyle"}},"narrative":"%22Last%20time%2C%20on%20Huntr%2Fx%20Quest%22%3A%0A%0AThe%20girls%20fell%20into%20a%20series%20of%20vile%20traps%20and%20ambushes%20in%20the%20castle%2C%20but%20managed%20to%20fight%20their%20way%20to%20the%20throne%20room.%20%20Agwi%20Hwasin%20was%20nowhere%20to%20be%20found%2C%20but%20they%20did%20manage%20to%20defeat%20his%20right%20hand%20ally%2C%20and%20in%20doing%20so%20find%20the%20keys%20to%20the%20castle's%20dungeon.%20%20With%20hope%20that%20they%20might%20find%20Celine%20inside%2C%20they%20opened%20the%20massive%20doors%20and%20entered%20the%20dungeon's%20murky%20and%20dark%20hallways.%0A%0A---%0A%0ANow%20heroes%2C%20prepare%20yourselves%20for%20quest%209%3A%20The%20Dungeons%20of%20Agwisanseong.%0A%0AThe%20dungeon%20appears%20to%20be%20a%20complex%20structure%2C%20with%20numerous%20isolated%20cell%20blocks%20as%20you%20head%20further%20in.%20%20When%20you%20first%20entered%2C%20you%20quickly%20dispatched%20a%20guard%20who%20had%20a%20note%20indicating%20that%20Celine%20was%20brought%20to%20the%20deepest%20cell%20block%3A%20Cell%20Block%20D.%20%20You'll%20have%20to%20work%20your%20way%20through%20the%20complex%20to%20reach%20her.","notes":"%C2%A7MD%C2%A7**X**%20-%20The%20girls%20start%20here.%0A%0AWhen%20they%20return%20here%20with%20Celine%2C%20the%20quest%20ends.%20%20Say%3A%0A%0A*Celine%20stares%20in%20disbelief%20at%20the%20girls%20for%20a%20moment%20before%20finally%20speaking.%20%20%22I...%20I%20can't%20believe%20you%20saved%20me%2C%20here%20of%20all%20places.%20%20How%20did%20you%20make%20it%20here%20alive%3F%20%20You%20must%20be%20the%20most%20talented%20fighters%20in%20the%20world!%20%20Come%20on%2C%20let's%20get%20out%20of%20here.%20%20Agwi%20Hwasin%20is%20out%20there%20somewhere%2C%20making%20a%20plan.%20%20We%20need%20to%20find%20a%20way%20to%20lure%20him%20out.%0A%0AOver%20several%20hours%20and%20many%20more%20harrowing%20battles%2C%20the%20girls%20finally%20make%20their%20way%20back%20up%20the%20stairs%20and%20see%20sunlight%20once%20more.%20%20With%20the%20monk's%20help%2C%20they%20seal%20the%20portal%20behind%20them%20again.%0A%0AThe%20girls%20each%20get%20800gp%20of%20experience%20for%20bringing%20Celine%20to%20safety%20from%20the%20very%20depths%20of%20the%20underworld!*%0A%0A**A**%20-%20When%20a%20girl%20goes%20to%20open%20the%20door%3A%20*The%20door%20is%20marked%20%22Cell%20Block%20A%22.%20%20As%20you%20push%20open%20the%20door%2C%20rats%20scurry%20away%20into%20small%20holes%20in%20the%20walls.%0A%0A**B**%20-%20Upon%20searching%20in%20this%20room%2C%20the%20girls%20will%20find%20a%20Cell%20Block%20B%20security%20key%20in%20the%20lock%20box%2C%20as%20well%20as%20a%20Potion%20of%20Healing.%0A%0A**C**%20-%20When%20a%20girl%20goes%20to%20open%20the%20door%3A%20*The%20door%20is%20marked%20%22Cell%20Block%20B%22.*%20%20If%20they%20have%20the%20Cell%20Block%20B%20security%20key%2C%20say%3A%20*You%20insert%20the%20key%2C%20and%20it%20opens%20easily.*%0A%0A**D**%20-%20When%20a%20girl%20goes%20to%20open%20the%20door%3A%20*This%20thick%20iron%20door%20is%20marked%20'Cell%20Block%20D%22.*%20%20If%20they%20have%20the%20Cell%20Block%20D%20security%20key%2C%20say%3A%20*You%20insert%20the%20key%2C%20and%20it%20opens%20with%20the%20loud%20squeal%20of%20two%20pieces%20of%20heavy%20metal%20rubbing%20up%20against%20each%20other.*%0A%0A**E**%20-%20When%20one%20of%20these%20doors%20opens%2C%20all%20of%20them%20do%20simultaneously%2C%20revealing%20the%20contents.%0A%0A**F**%20-%20When%20a%20girl%20enters%20this%20hallway%2C%20reveal%20the%20hall's%20contents.%20%20Say%3A%0A%0A*There's%20pretty%20heavy%20security%20here%20guarding%20a%20lockbox.%20%20One%20of%20them%20seems%20to%20be%20some%20kind%20of%20heavily-armored%20mechanical%20monstrosity!*%0A%0AThe%20Chaos%20Sorcerer%20at%20F%20is%20a%20Demonic%20Tech%20Armor%2C%20an%20animated%20set%20of%20armor%20carved%20from%20the%20essence%20of%20hatred.%20%20It%20has%20the%20following%20stats%3A%0A%0AAttack%20Dice%3A%203%2C%20Ranged%20(%22it%20fires%20a%20magical%20missile!%22)%0ADefense%20Dice%3A%200%0ABody%20Points%3A%208%0AMind%20Points%3A%205%0AType%3A%20Tactical%0AManeuver%3A%20Shove%0ASpecial%3A%20Damage%20Negation%20(2)%20(%22Your%20attack%20bounces%20off%20of%20his%20heavy%20armor%20plating%3A%20you're%20going%20to%20need%20to%20hit%20harder%20than%20that%20to%20penetrate%20his%20armor!%22)%0A%0AWhen%20defeated%20and%20the%20heroes%20search%2C%20instead%20of%20pulling%20a%20treasure%20card%20say%3A%0A%0A*You%20find%20a%20Cell%20Block%20C%20key%20in%20the%20lockbox%2C%20along%20with%20100gp%20per%20hero%20and%20two%20Potions%20of%20Healing.*%0A%0A**G**%20-%20When%20a%20girl%20goes%20to%20open%20the%20door%3A%20*The%20door%20is%20marked%20%22Cell%20Block%20C%22.*%20%20If%20they%20have%20the%20Cell%20Block%20C%20security%20key%2C%20say%3A%20*You%20insert%20the%20key%2C%20and%20it%20opens%20easily.*%20%20All%20of%20the%20doors%20labeled%20G%20open%20at%20the%20same%20time%2C%20revealing%20their%20contents.%0A%0A**H**%20-%20When%20you%20enter%20this%20room%2C%20say%3A%20*This%20lockbox%20is%20guarded%20by%20the%20largest%20Fimir%20you%20have%20ever%20seen!*%0A%0AThe%20Monstrous%20Fimir%20has%20the%20following%20stats%3A%0AAttack%20Dice%3A%205%20(%22The%20runes%20on%20the%20monster's%20massive%20axe%20glow%20as%20the%20wound%20bites%20deeply%22)%0ADefense%20Dice%3A%203%0ABody%20Points%3A%207%0AMind%20Points%3A%204%0AType%3A%20Tactical%0AManeuver%3A%20Intimidate%0ASpecial%3A%20When%20the%20monster%20scores%20a%20hit%2C%20the%20runes%20on%20its%20axe%20glow%20and%20heal%20it%20one%20body%20point.%0A%0AWhen%20defeated%20and%20the%20heroes%20search%2C%20instead%20of%20pulling%20a%20treasure%20card%20they%20find%20Cell%20Block%20D's%20security%20card%20in%20the%20lockbox%2C%20along%20with%20100gp%20per%20hero.%0A%0A**I**%20-%20All%20of%20the%20doors%20labeled%20I%20open%20at%20the%20same%20time%2C%20revealing%20their%20contents.%20%20Say%3A%20*You%20can%20hear%20a%20familiar%20voice%20shouting%20angrily%20somewhere%20in%20this%20cell%20block%2C%20vowing%20revenge%20and%20groaning%20against%20their%20restraints.%20%20It's%20Celine!*%0A%0A**J**%20-%20When%20the%20girls%20open%20the%20door%2C%20say%3A%20*You%20find%20Celine%2C%20chained%20to%20table%20restraints%20as%20guards%20sit%20nearby%20amusing%20themselves%20with%20a%20game%20of%20cards.%20%20They%20stand%20up%20and%20grab%20their%20weapons%20when%20they%20see%20your%20intrusion!*%0A%0AWhen%20the%20enemies%20are%20defeated%2C%20say%3A%20*You%20unchain%20Celine%20from%20her%20restraints.%20%20She%20shakes%20her%20head%20in%20disbelief.%20%22How...%20how%20are%20you%20here%3F%20%20WHY%20are%20you%20here%3F%20%20You%20should%20have%20left%20me%2C%20it%20is%20far%20too%20dangerous.%22%20%20You%20hear%20distant%2C%20heavy%20footsteps%2C%20and%20Celine's%20eyes%20go%20wide.%20%20%22They%20know%20you're%20here.%20%20We%20have%20to%20run.%20%20GO!%22*%0A%0AFrom%20now%20on%2C%20the%20closest%20K%20location%20will%20spawn%20a%20wandering%20monster%20(Chaos%20Warrior)%20on%20each%20of%20Gwi-Ma's%20turns%2C%20who%20can%20move%20and%20act%20immediately%20on%20that%20turn.%0A%0A**K**%20-%20When%20(J)%20is%20activated%2C%20the%20closest%20of%20these%20to%20a%20hero%20will%20spawn%20a%20Chaos%20Warrior%20on%20each%20of%20Gwi-Ma's%20turns%20(up%20to%20a%20maximum%20of%204%20on%20the%20board%20at%20any%20time)%2C%20who%20can%20move%20and%20act%20immediately%20on%20that%20turn.%0A%0A**L**%20-%20When%20(J)%20is%20activated%2C%20this%20location%20becomes%20active.%20%20When%20a%20hero%20is%20in%20line%20of%20sight%20of%20this%20location%2C%20spawn%20a%20special%20Zombie%20named%20%22The%20Warden%22.%0A%0ASay%3A%20*Before%20you%20stands%20a%20menacing%20undead%20demon.%20%20It%20speaks%20to%20you%20in%20a%20low%2C%20gutteral%20tone.%20%20%22Children%2C%20I'm%20the%20warden%20of%20this%20here%20dungeon%20and%20it%20looks%20like%20you're%20attempting%20a%20jailbreak.%20%20That's%20not%20going%20to%20happen%20under%20my%20watch.%20%20Let's%20see%20if%20you%20can%20hit%20me.%20%20Give%20it%20your%20best%20shot.%22*%0A%0AIt%20has%20the%20following%20stats%3A%0AAttack%20Dice%3A%204%0ADefense%20Dice%3A%2010%2C%20reducing%20by%202%20at%20the%20end%20of%20each%20Gwi-Ma%20round.%20(*At%20the%20end%20of%20the%20round%2C%20you%20see%20the%20Warden's%20undead%20body%20start%20to%20decay.%20%20A%20chunk%20of%20him%20just%20fell%20off%2C%20gross!*)%0ABody%20Points%3A%201%0AMind%20Points%3A%206%0AType%3A%20Mindless%0AManeuver%3A%20Shove%0ASpecial%3A%20Damage%20Negation%20(2)%20(%22You%20knock%20off%20a%20piece%20of%20him%2C%20but%20he%20seems%20unphased%20by%20it.%20%20Must%20not%20have%20been%20an%20important%20piece.%22)%0A%0AIf%20the%20Warden's%20defense%20dice%20reach%200%20before%20he%20is%20killed%2C%20say%3A%20*Suddenly%2C%20you%20see%20the%20warden's%20eyes%20widen.%20%20His%20decaying%20form%20finally%20gives%20away%20completely%2C%20and%20he%20falls%20into%20pieces%20on%20the%20ground%20before%20you.*","wanderingMonster":"Chaos%20Warrior","style":"hq-us"},{"id":"b664640e-b6fe-4e33-b08b-15c978f4c1d6","title":"10.%20Diss%20Track","author":"","created":"2026-06-16T14:02:41.641Z","updated":"2026-06-25T13:50:42.305Z","layout":"defaultMap","map":{"M10":{"annotation":"letterA","homebrew":"https://images2.imgbox.com/c6/71/Bs4ly6Qo_o.png||8-7__","background":"homebrew_N_8-7__"},"J13":{"annotation":"letterX"},"J14":{"annotation":"letterX"},"G10":{"annotation":"letterA"},"G17":{"annotation":"letterA"},"M17":{"annotation":"letterA"},"S13":{"annotation":"letterB"},"S14":{"annotation":"letterB"},"J26":{"annotation":"letterB"},"J1":{"annotation":"letterB"},"A13":{"annotation":"letterB"},"A14":{"annotation":"letterB"},"K1":{"tile":"blockedwall"},"I1":{"tile":"blockedwall"},"A12":{"tile":"blockedwall"},"A15":{"tile":"blockedwall"},"I26":{"tile":"blockedwall"},"K26":{"tile":"blockedwall"},"S15":{"tile":"blockedwall"},"S2":{"door":"doorN"},"O3":{"furniture":"chestN"},"P5":{"furniture":"bookcaseE"},"P2":{"furniture":"bookcase