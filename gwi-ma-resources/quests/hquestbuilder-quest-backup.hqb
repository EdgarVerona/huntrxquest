"C5":{"annotation":"rock"},"C6":{"annotation":"rock"},"C7":{"annotation":"rock"},"C8":{"annotation":"rock"},"C9":{"annotation":"rock"},"B9":{"annotation":"rock"},"B8":{"annotation":"rock"},"B7":{"annotation":"rock"},"B6":{"annotation":"rock"},"B5":{"annotation":"rock"},"B4":{"annotation":"rock"},"B3":{"annotation":"rock"},"B2":{"annotation":"rock"},"C16":{"door":"staircaseN"},"A26":{"annotation":"letterQ"},"S15":{"tile":"blockedwall"},"S16":{"annotation":"letterM"},"S17":{"tile":"blockedwall"},"S18":{"annotation":"letterN"},"S19":{"tile":"blockedwall"},"S20":{"annotation":"letterO"},"S21":{"tile":"pittrap"},"S23":{"tile":"pittrap"},"S22":{"tile":"speartrap"},"S24":{"tile":"speartrap"},"S25":{"tile":"pittrap"},"J16":{"annotation":"letterP"},"S14":{"annotation":"letterL"},"R26":{"tile":"speartrap"},"L2":{"furniture":"throneW"},"F9":{"annotation":"letterH"},"E5":{"annotation":"letterH"},"M21":{"door":"doorE"},"M22":{"annotation":"letterJ"},"N20":{"door":"doorS","annotation":"letterJ"},"R20":{"furniture":"bookcaseN"},"Q20":{"creature":"dreadwarrior"},"L24":{"furniture":"sorcererstableN"},"E12":{"furniture":"cupboardE"},"H7":{"furniture":"tableE"},"E3":{"furniture":"rackS"},"H4":{"creature":"mummy"},"G4":{"creature":"mummy"},"E7":{"creature":"zombie"},"F7":{"creature":"zombie"},"D10":{"creature":"skeleton"},"C12":{"creature":"skeleton"},"D11":{"creature":"skeleton"},"M24":{"creature":"orc"},"M25":{"creature":"orc"},"K20":{"creature":"goblin"},"M19":{"creature":"goblin"},"N15":{"annotation":"rock"},"N16":{"annotation":"rock"},"N17":{"annotation":"rock"},"N18":{"annotation":"rock"},"O18":{"annotation":"rock"},"O17":{"annotation":"rock"},"O16":{"annotation":"rock"},"O15":{"annotation":"rock"},"P15":{"annotation":"rock"},"P16":{"annotation":"rock"},"P17":{"annotation":"rock"},"P18":{"annotation":"rock"},"Q18":{"annotation":"rock"},"Q17":{"annotation":"rock"},"Q16":{"annotation":"rock"},"Q15":{"annotation":"rock"},"R15":{"annotation":"rock"},"R16":{"annotation":"rock"},"R17":{"annotation":"rock"},"R18":{"annotation":"rock"},"R22":{"annotation":"rock"},"R23":{"annotation":"rock"},"R24":{"annotation":"rock"},"R25":{"annotation":"rock"},"Q25":{"annotation":"rock"},"Q24":{"annotation":"rock"},"Q23":{"annotation":"rock"},"Q22":{"annotation":"rock"},"P22":{"annotation":"rock"},"O22":{"annotation":"rock"},"O23":{"annotation":"rock"},"O24":{"annotation":"rock"},"O25":{"annotation":"rock"},"P25":{"annotation":"rock"},"P24":{"annotation":"rock"},"P23":{"annotation":"rock"},"H17":{"annotation":"rock"},"G17":{"annotation":"rock"},"G16":{"annotation":"rock"},"C19":{"furniture":"tombE"},"E18":{"creature":"chaossorcerer"},"G20":{"creature":"gargoyle"},"C22":{"annotation":"letterS"},"G19":{"creature":"orc"},"G21":{"creature":"orc"},"H26":{"annotation":"letterR"},"D16":{"annotation":"letterT"}},"narrative":"Last%20time%2C%20on%20Huntr%2FX%20Quest%3A%0A%0AThe%20girls%20entered%20the%20Library%20of%20Jang%2C%20which%20was%20overrun%20with%20demons%2C%20but%20managed%20to%20escape%20with%20the%20Chronicles%20of%20Mudang.%0A%0AAfter%20pouring%20over%20its%20pages%2C%20they%20learned%20a%20great%20deal.%0A%0AThe%20archdemon%20Agwi%20Hwasin%20has%20existed%20since%20time%20immemorial%2C%20spawned%20from%20the%20first%20act%20of%20pure%20malice%20committed%20by%20a%20human.%20%20He%20is%20as%20cunning%20as%20he%20is%20powerful%2C%20fueled%20by%20the%20hatred%20and%20contempt%20expressed%20by%20mankind%20towards%20each%20other.%20%20The%20last%20time%20he%20came%20to%20the%20surface%20hundreds%20of%20years%20ago%2C%20he%20attempted%20to%20conduct%20a%20ritual%20that%20would%20turn%20all%20of%20the%20humans%20in%20the%20world%20into%20soulless%20demons%20under%20his%20command.%20%20He%20was%20contained%20and%20pushed%20back%20to%20the%20underworld%2C%20but%20not%20truly%20defeated.%20%20It%20sounds%20like%20he%20must%20be%20back%20to%20finish%20the%20job%20he%20started%20long%20ago.%0A%0AIt%20also%20revealed%20that%20here%2C%20on%20Jeju%20Island%2C%20there%20exists%20a%20still%20active%20entrance%20to%20the%20underworld.%20%20It%20is%20said%20that%20an%20early%20group%20of%20hunters%20used%20this%20portal%20to%20try%20and%20attack%20Gwi-Ma%20directly%2C%20but%20when%20they%20never%20returned%20it%20was%20sealed%20and%20in%20time%20nearly%20forgotten.%20%20The%20monks%20who%20live%20at%20the%20temple%20built%20around%20it%20are%20some%20of%20the%20few%20people%20who%20remain%20that%20know%20it%20exists.%0A%0AFinally%2C%20you%20have%20found%20a%20way%20to%20save%20Celine.%20%20You%20resolve%20to%20head%20to%20Seoraksan%20and%20make%20your%20way%20up%20the%20mountain%20to%20reach%20this%20cavern%20temple%2C%20and%20from%20there%20into%20the%20underworld%20itself.%0A%0A---%0A%0ANow%20heroes%2C%20prepare%20yourselves%20for%20Chapter%205%3A%20The%20Secrets%20of%20Seoraksan.%0A%0AYou%20have%20journeyed%20far%20up%20the%20mountain%2C%20and%20have%20come%20to%20a%20cliffside%20temple.%20%20Further%20up%20one%20of%20these%20foreboding%20paths%20is%20the%20way%20to%20the%20cave%20where%20the%20passage%20is%20sealed%2C%20but%20you%20neither%20know%20which%20path%20to%20traverse%20nor%20how%20to%20unseal%20the%20passage%20when%20you%20get%20there.%20%20You%20decide%20to%20speak%20to%20the%20locals%20(speaking%20to%20NPCs%20uses%20your%20Action%20for%20the%20turn).","notes":"%C2%A7MD%C2%A7**X**%20-%20The%20girls%20start%20here.%0A%0A**A**%20-%20*You%20greet%20the%20monk%2C%20and%20ask%20if%20he%20knows%20anything%20about%20the%20entrance%20to%20the%20underworld.%20%20His%20eyes%20narrow%2C%20and%20he%20leans%20in%20to%20whisper%20to%20you.%20%20%22You%20seek%20passage%20into%20the%20underworld%3F%20%20I%20would%20not%20do%20that%20if%20I%20were%20you.%20%20It%20is%20dangerous%2C%20and%20if%20left%20unsealed%20the%20passage%20could%20unleash%20all%20manner%20of%20foul%20creatures.%20%20We%20have%20sealed%20the%20way%20for%20the%20protection%20of%20humanity.%20%20Please%20reconsider%20whatever%20it%20is%20that%20you%20are%20planning.%22%0A%0AMake%20an%20assisted%20Contested%20Mind%20Check%20vs.%203%20dice.%0A%0AIf%20you%20win%3A%0A%0A*You%20manage%20to%20convince%20the%20monk%20of%20the%20importance%20of%20your%20mission.%20%20%22Very%20well.%20%20I%20will%20remove%20the%20traps%20I%20set%20on%20the%20passage.%20%20The%20path%20lies%20directly%20to%20the%20East%20as%20you%20exit%20the%20temple%2C%20but%20will%20not%20be%20accessible%20until%20you%20convince%20the%20other%20monks%20to%20clear%20the%20obstacles%20they%20have%20put%20in%20the%20way.%22*%20%20(The%20traps%20at%20O%20are%20now%20disabled)%0A%0AIf%20you%20lose%3A%0A%0A*The%20monk%20hears%20your%20plea%2C%20but%20shakes%20his%20head.%20%20%22I%20am%20sorry%2C%20it%20is%20too%20dangerous.%20%20If%20you%20really%20want%20to%20do%20this%2C%20speak%20with%20the%20other%20monks.%20%20But%20you%20will%20get%20no%20help%20from%20me%20in%20this%20foolish%20endeavor.%22*%0A%0A**B**%20-%20*You%20greet%20this%20stout%20monk%20as%20he's%20in%20the%20midst%20of%20forging%20a%20new%20weapon.%20%20A%20fine%20rack%20of%20armaments%20stands%20nearby%2C%20and%20the%20walls%20are%20covered%20in%20the%20tools%20of%20his%20craft.%20%20%22Aye%20lad%2C%20yer%20seeking%20entrance%20to%20the%20underworld%20eh%3F%20%20Well%20I%20need%20something%20from%20ye%20first.%20%20The%20path%20to%20the%20north%20leads%20to%20my%20old%20cavern%20workshop%2C%20but%20the%20ceiling%20was%20crumbling%20and%20we%20had%20to%20abandon%20it.%20%20But%20I%20left%20my%20best%20hammer%20in%20there.%20%20If%20you%20bring%20it%20back%2C%20I%20can%20help%20you.%22%0A%0AIf%20you%20bring%20back%20his%20hammer%3A%0A%0A*%22Yes%2C%20this%20is%20the%20one!%20%20It's%20a%20fine%20hammer.%20%20Thank%20you.%20%20I'll%20make%20sure%20I%20open%20the%20stone%20blockage%20I%20put%20up.%20%20You'll%20need%20to%20talk%20with%20my%20fellow%20monks%20if%20you%20want%20the%20path%20to%20be%20completely%20opened%2C%20however.%22*%20(The%20stone%20at%20L%20is%20now%20removed)%0A%0A**C**%20-%20*This%20monk%20appears%20to%20be%20busy%20searching%20through%20books.%20%20He%20takes%20one%20off%20the%20nearby%20bookshelf%2C%20flips%20through%20frantically%2C%20and%20then%20puts%20it%20back%20to%20grab%20another.%20%20Finally%20he%20looks%20away%20from%20a%20book%20long%20enough%20to%20greet%20you%2C%20turning%20his%20head%20just%20barely%20in%20your%20direction.%20%20%22Ah%2C%20how%20long%20have%20you%20been%20standing%20here%3F%20%20Well%20no%20matter%2C%20no%20matter.%20%20I%20can't%20find%20my%20recipe%20book%2C%20and%20the%20monks%20are%20demanding%20my%20special%20stew!%20%20What%20did%20you%20say%3F%20%20You%20want%20passage%20to%20the%20underworld%3F%20%20I%20can%20remove%20my%20blockade%20along%20the%20path%20if%20you%20can%20retrieve%20my%20recipe%20book.%20%20Before%20I%20became%20a%20monk%2C%20I%20had%20a%20small%20cottage%20down%20the%20eastern%20path%2C%20and%20then%20turning%20to%20the%20north%20and%20east.%20%20I%20bet%20I%20left%20it%20there.%22*%0A%0AIf%20you%20bring%20back%20the%20recipe%20book%3A%0A%0A*%22Yes%2C%20yes%20this%20is%20it!%20%20Oh%20thank%20you!%20%20I%20will%20ensure%20that%20my%20obstacle%20is%20removed%20in%20time%20for%20your%20journey.%22*%20(The%20stone%20at%20M%20is%20now%20removed)%0A%0A**D**%20-%20*This%20monk%20is%20flipping%20through%20a%20large%20stack%20of%20papers%20on%20his%20desk.%20%20He%20looks%20up%20to%20greet%20you.%20%22Oh%2C%20good%20day%20to%20you.%20%20I%20heard%20that%20you%20are%20seeking%20passage%20to%20the%20underworld.%20%20It's%20a%20dangerous%20thing%20you're%20attempting%2C%20but%20I%20know%20that%20you%20hunters%20are%20capable%20of%20defending%20yourselves.%20%20There%20is%20something%20that%20I%20need%20from%20you%2C%20however%2C%20before%20you%20go.%20%20I%20am%20busy%20copying%20these%20documents%2C%20but%20I've%20run%20out%20of%20calligraphy%20ink.%20%20I%20left%20some%20in%20my%20storage%20locker%2C%20to%20the%20west%20and%20then%20north%20of%20here.%20%20I%20put%20it%20there%20to%20safeguard%20my%20valuables%2C%20but%20the%20place%20has%20been%20overrun%20by%20foul%20creatures.%20%20Could%20you%20dispatch%20them%20and%20return%20my%20calligraphy%20ink%3F%22*%0A%0AIf%20you%20bring%20back%20the%20ink%3A%0A%0A*%22Thank%20you%2C%20brave%20heroes!%20%20I%20will%20ensure%20that%2C%20for%20my%20part%2C%20your%20path%20will%20be%20clear.%20%20Make%20sure%20to%20talk%20to%20the%20others%20ere%20you%20depart.%20%20And%20good%20luck.%20%20The%20last%20hunters%20that%20passed%20through%20never%20returned.%22*%20(The%20stone%20at%20N%20is%20now%20removed)%0A%0A**E**%20-%20When%20the%20first%20hero%20exits%20the%20temple%2C%20say%3A%0A%0A*You%20exit%20the%20temple%20to%20find%20yourself%20on%20a%20perilously%20narrow%20trail%20dropping%20off%20to%20the%20side%20of%20the%20mountain.%20%20The%20trail%20splits%20here%2C%20both%20north%20and%20to%20the%20east%2C%20and%20both%20paths%20appear%20to%20be%20carved%20into%20the%20cliffside.%20%20This%20is%20a%20dangerous%20road%2C%20tread%20carefully.*%0A%0A**F**%20-%20Once%20the%20monsters%20in%20this%20corridor%20are%20defeated%2C%20a%20hero%20who%20searches%20will%20find%20calligraphy%20ink%20instead%20of%20pulling%20a%20treasure%20card.%0A%0A**G**%20-%20Once%20all%20four%20heroes%20pass%20by%20this%20falling%20stone%20trap%2C%20say%3A%0A%0A*It's%20a%20cave%20in!%20%20The%20path%20behind%20you%20is%20blocked.%20%20You'll%20need%20to%20find%20another%20way%20back.*%0A%0A**H**%20-%20*You%20come%20to%20a%20small%20wooden%20door%20mounted%20crudely%20over%20the%20entrance%20of%20a%20cave%2C%20its%20wood%20rotten%20and%20its%20hinges%20rusting.%20%20Pushing%20it%20open%2C%20you%20see%20the%20rusted%20evidence%20of%20an%20old%20smithery%2C%20and%20several%20demons%20milling%20about%20who%20turn%20towards%20you%20as%20the%20light%20from%20the%20newly%20opened%20door%20brightens%20the%20space%20for%20the%20first%20time%20in%20years.*%20%20(All%20other%20H%20doors%20open%20when%20the%20first%20one%20does).%0A%0A**I**%20-%20When%20the%20enemies%20are%20defeated%20and%20a%20search%20is%20performed%3A%0A%0A*You%20sift%20through%20the%20cobwebs%20and%20debris%2C%20until%20at%20last%20you%20find%20a%20smithing%20hammer%20among%20the%20detritus.%20%20What's%20more%2C%20you%20find%20a%20secret%20passage%20leading%20back%20out%20of%20the%20cavern.*%20(reveal%20the%20secret%20passage)%0A%0A**J**%20-%20*Here%20on%20the%20mountainside%2C%20you%20find%20a%20cozy%20but%20abandoned%20cottage.%20%20The%20light%20blue%20paint%20is%20peeling%20from%20the%20outer%20walls%2C%20and%20the%20door%20is%20suspiciously%20ajar.%20%20Pushing%20it%20open%2C%20you%20find%20demons%20rummaging%20through%20what%20remains!*%20(All%20other%20J%20doors%20open%20when%20the%20first%20one%20does)%0A%0AWhen%20they%20defeat%20the%20monsters%20here%20and%20search%2C%20they%20find%20a%20Recipe%20Book%20and%20a%20Potion%20of%20Concentrated%20Honmoon%20on%20the%20altar.%0A%0A**K**%20-%20A%20hero%20who%20reaches%20this%20chest%20can%20open%20it.%20%20Inside%20is%20200gp%20per%20hero%2C%20stashed%20away%20by%20a%20monk%20for%20a%20rainy%20day.%0A%0A**L**%20-%20When%20the%20first%20hero%20approaches%20it%3A%20*This%20stone%20seems%20strangely%20out%20of%20place.%20%20But%20you%20cannot%20seem%20to%20move%20it%20even%20though%20you%20push%20with%20all%20your%20might.*%20Removed%20with%20(B).%0A%0A**M**%20-%20Removed%20with%20(C).%0A%0A**N**%20-%20Removed%20with%20(D).%0A%0A**O**%20-%20If%20you%20convinced%20(A)%20to%20help%20you%2C%20remove%20all%20of%20these%20traps.%0A%0A**P**%20-%20*You%20come%20to%20a%20deep%20crevice%20in%20the%20mountain%2C%20with%20a%20rickety%20wooden%20bridge%20traversing%20it.%20%20But%20you%20are%20not%20alone%3A%20these%20demons%20appear%20to%20have%20been%20waiting%20for%20you!*%0A%0A**Q**%20-%20When%20the%20first%20hero%20reaches%20this%20tile%3A%20*Climbing%20up%20the%20steepest%20cliffside%20passage%2C%20you%20can%20at%20last%20see%20the%20entrance%20to%20a%20cave%20in%20the%20distance.%20%20Surely%20this%20must%20be%20where%20the%20passage%20to%20the%20underworld%20was%20sealed.*%20(Place%20the%20secret%20passage%20markers%20in%20each%20of%20the%20following%20rooms%20as%20soon%20as%20the%20heroes%20are%20able%20to%20see%20them%2C%20but%20do%20not%20reveal%20the%20contents%20of%20the%20next%20room%20until%20directed)%0A%0A**R**%20-%20As%20you%20reach%20this%20tile%3A%20*You%20have%20made%20it%20to%20the%20entrance%20of%20a%20small%20and%20very%20dark%20cave.%20%20Your%20torch%20can%20barely%20penetrate%20the%20darkness.%20%20The%20air%20is%20foul%2C%20as%20if%20sulfur%20is%20billowing%20out%20from%20some%20passage%20deeper%20within.%20%20Proceed%20carefully.%20%20(When%20a%20hero%20enters%20a%20room%2C%20reveal%20the%20passage%20to%20the%20next%20room%20and%20any%20contents%20of%20the%20current%20room%2C%20but%20no%20further)%0A%0A**S**%20-%20As%20a%20hero%20reaches%20this%20tile%3A%20*Pushing%20through%20this%20passage%2C%20previously%20unseen%20candles%20along%20the%20walls%20light%20up%2C%20revealing%20a%20stone%20tomb%20-%20and%20horrifying%20demons!%20%20The%20nearest%20demon%20reaches%20towards%20you%20with%20a%20flame-enwrapped%20hand%20as%20it%20scowls%20menacingly.%20%20Defend%20yourselves!*%0A%0AAll%20of%20the%20secret%20passages%20immediately%20open.%20%20Reveal%20all%20of%20the%20contents%20of%20each%20room.%0A%0AThe%20Chaos%20Sorcerer%20has%20the%20following%20stats%3A%0AAttack%3A%202%0ADefense%3A%203%0ABody%20Points%3A%207%0AMind%20Points%3A%208%0AType%3A%20Tactical%0AManeuver%3A%20Recharge%0ASpells%3A%20Ball%20of%20Flame%2C%20Firestorm%2C%20Summon%20Undead.%0A%0AUpon%20searching%2C%20the%20heroes%20will%20find%20300gp%20in%20the%20old%20tomb%20instead%20of%20drawing%20a%20treasure%20card.%0A%0AT%20%3D%20When%20the%20heroes%20make%20it%20onto%20this%20tile%2C%20say%3A%0A%0A*The%20dimly%20lit%20passage%20descends%20into%20what%20looks%20like%20total%20darkness.%20%20This%20must%20be%20what%20you%20were%20looking%20for.%20%20The%20overpowering%20scent%20of%20sulfur%20emanating%20from%20the%20passage%20fills%20your%20nostrils.%20With%20Celine%20in%20your%20thoughts%2C%20you%20bravely%20begin%20the%20long%20descent%20into%20the%20underworld.%20%20Your%20bravery%20gains%20each%20of%20you%20500gp%20worth%20of%20experience%20and%20wisdom.*%0A","wanderingMonster":"Orc","style":"hq-us","homebrew":["https://images2.imgbox.com/8c/92/TcZdB5yD_o.png||6-5__"]},{"id":"d7431259-d33e-46e8-96ff-f45f449bbc38","title":"6.%20The%20Temple%20of%20Infinite%20Abyss","author":"","created":"2026-06-16T09:08:38.000Z","updated":"2026-06-25T14:12:39.768Z","layout":"defaultMap","map":{"S13":{"annotation":"letterX"},"S14":{"annotation":"letterX"},"P13":{"door":"doorW","annotation":"letterA"},"P14":{"door":"doorE","annotation":"letterA"},"M13":{"door":"doorN","annotation":"letterA"},"M14":{"door":"doorN","annotation":"letterA"},"I14":{"door":"staircaseN"},"J13":{"creature":"dreadwarrior"},"J14":{"creature":"dreadwarrior"},"J15":{"creature":"dreadwarrior"},"J12":{"creature":"dreadwarrior"},"K16":{"creature":"goblin"},"K11":{"creature":"goblin"},"S2":{"annotation":"letterB"},"N13":{"annotation":"letterB"},"N14":{"annotation":"letterB"},"P1":{"creature":"orc"},"J10":{"creature":"orc"},"I17":{"creature":"orc"},"J25":{"annotation":"letterB"},"B1":{"creature":"orc"},"A11":{"annotation":"letterB"},"F14":{"annotation":"letterB"},"F13":{"annotation":"letterB"},"C14":{"door":"doorE","annotation":"letterC"},"D17":{"door":"doorE"},"C21":{"door":"doorE"},"E24":{"creature":"abomination"},"E22":{"creature":"abomination"},"C22":{"annotation":"letterE"},"C25":{"furniture":"weaponsrackE"},"C24":{"annotation":"letterF"},"C15":{"annotation":"letterD"},"D18":{"annotation":"letterD"},"B17":{"creature":"orc"},"F17":{"creature":"orc"},"B19":{"creature":"orc"},"B20":{"creature":"orc"},"F18":{"annotation":"rock"},"F19":{"annotation":"rock"},"F20":{"annotation":"rock"},"F21":{"annotation":"rock"},"F22":{"annotation":"rock"},"F23":{"annotation":"rock"},"F24":{"annotation":"rock"},"F25